{
  "name": "playwright-automation",
  "version": "1.0.0",
  "description": "Playwright test automation framework for SauceDemo UI and Simple Books API",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui",
    "test:api": "npx playwright test tests/api",
    "test:headed": "npx playwright test --headed",
    "test:chrome": "npx playwright test --project=chrome",
    "test:firefox": "npx playwright test --project=firefox",
    "report": "npx playwright show-report reports/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}
